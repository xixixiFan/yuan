{
  "name": "yuan-ui",
  "author": "style'me",
  "version": "0.8.8",
  "private": false,
  "type": "module",
  "sideEffects": [
    "*.css",
    "*.scss",
    "**/styles/*.css",
    "**/styles/*.scss"
  ],
  "main": "./dist/yuan-ui.umd.js",
  "module": "./dist/yuan-ui.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/yuan-ui.es.js",
      "require": "./dist/yuan-ui.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./styles/index.css": "./dist/styles/index.css"
  },
  "description": "yuan-ui - A Vue 3 + TypeScript Enterprise UI Component Library",
  "keywords": [
    "vue",
    "vue3",
    "vuejs",
    "vite",
    "yuan-ui",
    "ui",
    "vueui",
    "components",
    "vue组件库",
    "vue3组件库",
    "typescript",
    "enterprise"
  ],
  "files": [
    "dist/*",
    "packages/*"
  ],
  "license": "MIT",
  "homepage": "https://yuanui.com/",
  "bugs": {
    "url": "https://yuanui.com/",
    "email": "1046674804@qq.com"
  },
  "scripts": {
    "dev": "vite --port 3002",
    "build": "vue-tsc --noEmit && vite build",
    "build:lib": "vite build",
    "build:html": "vite build --config ./build/build.js",
    "preview": "vite preview",
    "yuan-ui": "vite build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx --fix",
    "cz": "git-cz"
  },
  "peerDependencies": {
    "vue": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-vue": "^4.5.0",
    "@vitest/coverage-v8": "^0.34.0",
    "@vue/runtime-core": "^3.4.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.20.0",
    "highlight.js": "^11.9.0",
    "jsdom": "^24.0.0",
    "pinia": "^2.1.0",
    "sass": "^1.97.3",
    "typescript": "^5.3.0",
    "vite": "^4.5.0",
    "vite-plugin-dts": "^3.6.0",
    "vite-plugin-md": "^0.21.5",
    "vitepress": "^1.3.4",
    "vitest": "^0.34.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0",
    "vue-tsc": "^1.8.0"
  },
  "engines": {
    "node": ">= 18"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
